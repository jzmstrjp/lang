generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Problem {
  id                       String    @id @default(cuid())
  wordCount                Int
  englishSentence          String
  japaneseSentence         String
  japaneseReply            String
  englishReply             String
  incorrectOptions         Json
  audioEnUrl               String?
  audioEnReplyUrl          String?
  audioJaUrl               String?
  imageUrl                 String?
  audioReady               Boolean   @default(false)
  senderVoice              VoiceType
  senderName               String
  senderRole               String
  receiverVoice            VoiceType
  receiverName             String
  receiverRole             String
  place                    String
  how                      String
  senderWhen               String
  receiverPlace            String
  senderWhy                String
  senderWant               String
  difficultyLevel          Int?
  expression               String
  expressionJa             String
  senderAppearance         String?
  receiverAppearance       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([englishSentence])
  @@index([audioReady, difficultyLevel], map: "idx_problems_audio_ready_difficulty")
  @@index([audioReady, wordCount, difficultyLevel], map: "idx_problems_audio_wordcount_difficulty")
  @@index([audioReady, wordCount, createdAt(sort: Desc)], map: "idx_problems_audio_wordcount_createdat_desc")
  @@index([audioReady, wordCount, difficultyLevel, expression, expressionJa], map: "idx_problems_audio_wordcount_difficulty_expression")
  @@map("problems")
}

enum VoiceType {
  male
  female
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model Word {
  id         String   @id @default(cuid())
  expression   String
  expressionJa String
  isKids       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([expression, expressionJa])
  @@index([isKids])
  @@map("words")
}

model EnglishSentenceQualityLog {
  id                  String   @id @default(cuid())
  expression          String
  wordCountLength     String
  prompt              String
  englishSentence     String
  isOk                Boolean
  reason              String
  correctSentenceDraft String?

  createdAt DateTime @default(now())

  @@index([expression])
  @@index([isOk])
  @@map("english_sentence_quality_logs")
}
